            margin-bottom: 12px;
        }

        .upload-controls {
            display: flex;
            gap: 10px;
            align-items: center;
            flex-wrap: wrap;
        }

        .upload-controls input[type="file"] {
            flex: 1;
            min-width: 180px;
            padding: 10px;
            border: 1px dashed var(--border-color);
            border-radius: 10px;
            background: white;
            color: var(--text-secondary);
        }

        .upload-button {
            padding: 10px 16px;
            border: none;
            border-radius: 10px;
            background: var(--text-primary);
            color: white;
            font-weight: 600;
            cursor: pointer;
        }

        .upload-button:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .upload-summary {
            margin-top: 12px;
            font-size: 13px;
            color: var(--text-secondary);
        }

        .editor-tabs {
            display: flex;
            background: var(--bg-secondary);
            border-bottom: 1px solid var(--border-color);
        }

        .tab-button {
            flex: 1;
            padding: 12px 20px;
            background: none;
            border: none;
            cursor: pointer;
            font-size: 14px;
            font-weight: 500;
            color: var(--text-secondary);
            transition: all 0.2s ease;
            border-bottom: 2px solid transparent;
        }

        .tab-button.active {
            color: var(--primary-color);
            border-bottom-color: var(--primary-color);
            background: rgba(102, 126, 234, 0.03);
        }

        .tab-content {
            flex: 1;
            padding: 20px;
            overflow-y: auto;
            overflow-x: hidden;
            min-height: 0; /* Important for flex scrolling */
            max-height: 100%; /* Ensure it doesn't exceed container */
        }

        .document-item {
            background: var(--bg-secondary);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            margin-bottom: 15px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
        }

        .document-item:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(0,0,0,0.15);
        }

        .document-header {
            padding: 15px 20px;
            background: linear-gradient(135deg, #f8f9fa, #e9ecef);
            border-bottom: 1px solid var(--border-color);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .document-id {
            font-weight: 600;
            color: var(--primary-color);
            font-size: 14px;
        }

        .document-source {
            font-size: 12px;
            color: var(--text-secondary);
            font-style: italic;
        }

        .document-text {
            padding: 20px;
        }

        .document-text textarea {
            width: 100%;
            min-height: 120px;
            border: none;
            outline: none;
            font-family: inherit;
            font-size: 14px;
            line-height: 1.5;
            color: var(--text-primary);
            background: transparent;
            resize: vertical;
        }

        .save-section {
            padding: 24px;
            background: var(--bg-secondary);
            border-top: 1px solid var(--border-color);
        }

        .save-button {
            width: 100%;
            padding: 14px 16px;
            background: var(--primary-color);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s ease;
            box-shadow: none;
            white-space: nowrap;
            overflow: visible;
            min-height: 48px;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            line-height: 1.3;
            box-sizing: border-box;
        }

        .save-button.loading {
            background: #f59e0b;
            color: black;
        }

        .save-button.success {
            background: #10b981;
            color: grey;
        }

        .save-button.error {
            background: #ef4444;
            color: black;
        }

        .save-button:hover {
            background: var(--primary-dark);
            transform: none;
        }

        .save-button:disabled {
            background: #ccc;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }


        .notification {
            position: fixed;
            top: 20px;
            right: 20px;
            padding: 15px 20px;
            border-radius: 12px;
            color: grey;
            font-weight: 600;
            z-index: 1000;
            transform: translateX(400px);
            transition: all 0.3s ease;
            box-shadow: 0 4px 20px rgba(0,0,0,0.2);
        }

        .notification.show {
            transform: translateX(0);
        }

        .notification.success { background: var(--success-color); }
        .notification.error { background: var(--error-color); }
        .notification.info { background: var(--info-color); }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes typing {
            0%, 60%, 100% { transform: translateY(0); }
            30% { transform: translateY(-10px); }
        }

        /* Responsive Design */
        @media (max-width: 1200px) {
            .app-container {
                grid-template-columns: 1fr;
                grid-template-rows: 1fr auto;
                height: 95vh;
            }
            
            .editor-section {
                max-height: 400px;
            }
        }

        @media (max-width: 768px) {
            body {
                padding: 10px;
            }
            
            .app-container {
                border-radius: 10px;
                height: 95vh;
            }
            
            .message-content {
                max-width: 85%;
            }
            
            .chat-header h1 {
                font-size: 20px;
            }
            
            .editor-header h2 {
                font-size: 16px;
            }
        }
    </style>
</head>
<body>
    <div class="app-container">
        <!-- Chat Section -->
        <div class="chat-section">
            <div class="chat-header">
                <h1>Customer Support</h1>
                <p>Chat with our AI assistant for help with orders, returns, and policies</p>
            </div>
            
            <div class="status" id="status">Checking connection...</div>
            
            <div class="chat-messages" id="messages">
                <div class="message bot">
                    <div class="message-avatar">✨</div>
                    <div class="message-content">
                        Welcome to the AI Assistant! 👋
                        <br><br>
                        I can help you with:
                        • Questions about policies and services
                        • Return and shipping information
                        • Customer support inquiries
                        <br><br>
                        You can also edit the knowledge base documents on the right panel and update the vector database in real-time!
                    </div>
                </div>
            </div>
            
            <div class="typing-indicator" id="typing">
                <div class="message-avatar">💭</div>
                <div class="typing-content">
                    <span style="color: var(--text-secondary); font-size: 14px; margin-right: 8px;">Thinking</span>
                    <div class="typing-dots">
                        <span></span>
                        <span></span>
                        <span></span>
                    </div>
                </div>
            </div>
            
            <div class="chat-input">
                <input type="text" id="messageInput" placeholder="Ask me anything about our policies..." maxlength="500">
                <button onclick="sendMessage()" id="sendBtn">Send</button>
            </div>
        </div>

        <!-- Document Editor Section -->
        <div class="editor-section">
            <div class="editor-header">
                <div>
                    <h2>📋 Knowledge Base Editor</h2>
                    <p>Edit documents, upload multimodal files, and update the vector database</p>
                </div>
            </div>

            <div class="upload-panel">
                <h3>Upload a document</h3>
                <p>PDF, PNG, JPG, JPEG, and DOCX files are extracted into searchable text, OCR, and image captions.</p>
                <div class="upload-controls">
                    <input type="file" id="fileInput" accept=".pdf,.png,.jpg,.jpeg,.docx" />
                    <button class="upload-button" id="uploadBtn" onclick="uploadDocument()">Upload</button>
                </div>
                <div class="upload-summary" id="uploadSummary">No file uploaded yet.</div>
            </div>

            <div class="editor-tabs">
                <button class="tab-button active" onclick="switchTab('documents')">Documents</button>
                <button class="tab-button" onclick="switchTab('settings')">Settings</button>
            </div>

            <div class="tab-content" id="documentsTab">
                <div id="documentsContainer">
                    <!-- Documents will be loaded here -->
                </div>
            </div>

            <div class="tab-content" id="settingsTab" style="display: none;">
                <div style="text-align: center; padding: 40px 20px; color: var(--text-secondary);">
                    <h3>⚙️ Settings</h3>
                    <p>Advanced settings and configurations coming soon!</p>
                    <br>
                    <div style="background: var(--bg-secondary); padding: 20px; border-radius: 12px; text-align: left;">
                        <h4 style="margin-bottom: 10px;">Current Configuration:</h4>
                        <p><strong>API Endpoint:</strong> http://localhost:8000</p>
                        <p><strong>Embedding Model:</strong> text-embedding-3-small</p>
                        <p><strong>Chat Model:</strong> gpt-4o</p>
                        <p><strong>Top-K Results:</strong> 6</p>
                    </div>
                </div>
            </div>

            <div class="save-section">
                <button class="save-button" id="saveBtn" onclick="saveDocuments()">
                    <span id="saveText">💾 Save</span>
                </button>
            </div>
        </div>
    </div>

    <!-- Notification -->
    <div class="notification" id="notification"></div>

    <script>
        // Automatically detect the correct API base URL
        const API_BASE_URL = window.location.origin;
        const messagesContainer = document.getElementById('messages');
        const messageInput = document.getElementById('messageInput');
        const sendBtn = document.getElementById('sendBtn');
        const typingIndicator = document.getElementById('typing');
        const statusDiv = document.getElementById('status');
        const documentsContainer = document.getElementById('documentsContainer');
        const saveBtn = document.getElementById('saveBtn');
        const notification = document.getElementById('notification');
        const fileInput = document.getElementById('fileInput');
        const uploadBtn = document.getElementById('uploadBtn');
        const uploadSummary = document.getElementById('uploadSummary');

        let documents = [];
        let currentTab = 'documents';

        // Initialize the application
        init();

        async function init() {
            await checkHealth();
            await loadDocuments();
            messageInput.focus();
        }

        // Send message on Enter key
        messageInput.addEventListener('keypress', function(e) {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendMessage();
            }
        });

        async function checkHealth() {
            try {
                const response = await fetch(`${API_BASE_URL}/healthz`);
                if (response.ok) {
                    const data = await response.json();
                    if (data.database_connected) {
                        statusDiv.textContent = 'System ready';
                        statusDiv.className = 'status connected';
                    } else {
                        statusDiv.textContent = 'Database connection issues';
                        statusDiv.className = 'status warning';
                    }
                } else {
                    throw new Error('Server not responding');
                }
            } catch (error) {
                statusDiv.textContent = 'Connection unavailable';
                statusDiv.className = 'status error';
            }
        }

        async function loadDocuments() {
            try {
                // Fetch documents from the API
                const response = await fetch(`${API_BASE_URL}/documents`);
                if (response.ok) {
                    const data = await response.json();
                    documents = data.documents || [];
                    console.log(`✅ Loaded ${documents.length} documents from API`);
                } else {
                    console.warn('Failed to fetch documents from API, using fallback');
                    // Fallback to empty array - user can add documents manually
                    documents = [];
                }
            } catch (error) {
                console.error('Error loading documents:', error);
                // Fallback to empty array
                documents = [];
            }

            renderDocuments();
        }

        function renderDocuments() {
            documentsContainer.innerHTML = '';
            
            documents.forEach((doc, index) => {
                const docElement = document.createElement('div');
                docElement.className = 'document-item';
                docElement.innerHTML = `
                    <div class="document-header">
                        <div>
                            <div class="document-id">${doc.chunk_id}</div>
                            <div class="document-source">${doc.source}</div>
                        </div>
                    </div>
                    <div class="document-text">
                        <textarea 
                            id="doc-${index}" 
                            placeholder="Enter document content..."
                            oninput="updateDocument(${index}, this.value)"
                        >${doc.text}</textarea>
                    </div>
                `;
                documentsContainer.appendChild(docElement);
            });
        }

        function updateDocument(index, text) {
            documents[index].text = text;
        }

        function switchTab(tabName) {
            currentTab = tabName;
            
            // Update tab buttons
            document.querySelectorAll('.tab-button').forEach(btn => {
                btn.classList.remove('active');
            });
            document.querySelector(`button[onclick="switchTab('${tabName}')"]`).classList.add('active');
            
            // Show/hide tab content
            document.getElementById('documentsTab').style.display = tabName === 'documents' ? 'block' : 'none';
            document.getElementById('settingsTab').style.display = tabName === 'settings' ? 'block' : 'none';
        }

        async function saveDocuments() {
            const saveText = document.getElementById('saveText');
            const originalText = saveText.innerHTML;
            
            saveBtn.disabled = true;
            saveBtn.classList.add('loading');
            saveBtn.classList.remove('success', 'error');
            saveText.innerHTML = '🔄 Saving...';

            try {
                const response = await fetch(`${API_BASE_URL}/seed`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        docs: documents
                    })
                });

                if (response.ok) {
                    const data = await response.json();
                    showNotification(`✅ Successfully updated ${data.inserted} documents in database!`, 'success');
                    saveBtn.classList.remove('loading');
                    saveBtn.classList.add('success');
                    saveText.innerHTML = '✅ Saved!';
                    
                    setTimeout(() => {
                        saveText.innerHTML = originalText;
                        saveBtn.classList.remove('success');
                    }, 2000);
                } else {
                    throw new Error('Failed to save documents');
                }
            } catch (error) {
                showNotification('❌ Failed to update database. Please try again.', 'error');
                saveBtn.classList.remove('loading');
                saveBtn.classList.add('error');
                saveText.innerHTML = '❌ Failed';
                
                setTimeout(() => {
                    saveText.innerHTML = originalText;
                    saveBtn.classList.remove('error');
                }, 2000);
            } finally {
                saveBtn.disabled = false;
                saveBtn.classList.remove('loading');
            }
        }

        function showNotification(message, type = 'info') {
            notification.textContent = message;
            notification.className = `notification ${type}`;
            notification.classList.add('show');
            
            setTimeout(() => {
                notification.classList.remove('show');
            }, 4000);
        }

        function addMessage(content, isUser = false, citations = [], sources = [], images = []) {
            const messageDiv = document.createElement('div');
            messageDiv.className = `message ${isUser ? 'user' : 'bot'}`;
            
            const avatar = document.createElement('div');
            avatar.className = 'message-avatar';
            avatar.textContent = isUser ? '👤' : '✨';
            
            const contentDiv = document.createElement('div');
            contentDiv.className = 'message-content';
            contentDiv.innerHTML = content.replace(/\n/g, '<br>');
            
            if (citations.length > 0) {
                const citationsDiv = document.createElement('div');
                citationsDiv.className = 'citations';
                citationsDiv.innerHTML = `📚 Sources: ${citations.join(', ')}`;
                contentDiv.appendChild(citationsDiv);
            }

            if (!isUser && (sources.length > 0 || images.length > 0)) {
                const metadataDiv = document.createElement('div');
                metadataDiv.className = 'answer-metadata';

                if (sources.length > 0) {
                    const sourceList = document.createElement('div');
                    sourceList.className = 'source-list';
                    sourceList.innerHTML = sources.map(source => {
                        const pageLabel = source.page_number != null ? `Page ${source.page_number}` : 'No page';
                        const caption = source.caption ? ` - ${source.caption}` : '';
                        return `<div class="source-item"><strong>${source.chunk_id}</strong> · ${source.item_type} · ${pageLabel}<br>${source.source}${caption}</div>`;
                    }).join('');
                    metadataDiv.appendChild(sourceList);
                }

                if (images.length > 0) {
                    const imageList = document.createElement('div');
                    imageList.className = 'image-list';
                    imageList.innerHTML = images.map(image => {
                        const pageLabel = image.page_number != null ? `Page ${image.page_number}` : 'No page';
                        const caption = image.caption ? ` - ${image.caption}` : '';
                        return `<div class="image-item"><strong>${image.chunk_id}</strong> · ${pageLabel}<br>${image.image_path}${caption}</div>`;
                    }).join('');
                    metadataDiv.appendChild(imageList);
                }

                contentDiv.appendChild(metadataDiv);
            }
            
            if (isUser) {
                messageDiv.appendChild(contentDiv);
                messageDiv.appendChild(avatar);
            } else {
                messageDiv.appendChild(avatar);
                messageDiv.appendChild(contentDiv);
            }
            
            messagesContainer.appendChild(messageDiv);
            messagesContainer.scrollTop = messagesContainer.scrollHeight;
        }

        function showTyping() {
            typingIndicator.style.display = 'flex';
            messagesContainer.scrollTop = messagesContainer.scrollHeight;
        }

        function hideTyping() {
            typingIndicator.style.display = 'none';
        }

        async function sendMessage() {
            const message = messageInput.value.trim();
            if (!message) return;

            // Add user message
            addMessage(message, true);
            messageInput.value = '';
            sendBtn.disabled = true;
            showTyping();

            try {
                const response = await fetch(`${API_BASE_URL}/answer`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        query: message,
                        top_k: 6
                    })
                });

                if (response.ok) {
                    const data = await response.json();
                    hideTyping();
                    addMessage(data.text, false, data.citations || [], data.sources || [], data.images || []);
                } else {
                    hideTyping();
                    addMessage('Sorry, I encountered an error processing your question. Please try again later. 🔧', false);
                }
            } catch (error) {
                hideTyping();
                addMessage('Sorry, I cannot connect to the server. Please make sure it\'s running and try again. 🔌', false);
            } finally {
                sendBtn.disabled = false;
                messageInput.focus();
            }
        }

        async function uploadDocument() {
            const file = fileInput.files[0];
            if (!file) {
                showNotification('Please choose a PDF, image, or DOCX file first.', 'info');
                return;
            }

            uploadBtn.disabled = true;
            uploadBtn.textContent = 'Uploading...';
            uploadSummary.textContent = `Uploading ${file.name}...`;

            try {
                const formData = new FormData();
                formData.append('file', file);

                const response = await fetch(`${API_BASE_URL}/upload`, {
                    method: 'POST',
                    body: formData
                });

                if (!response.ok) {
                    throw new Error('Upload failed');
                }

                const data = await response.json();
                uploadSummary.textContent = `${data.filename} ingested as ${data.file_type}. ${data.chunks_inserted} chunks, ${data.images_extracted} images, ${data.pages_processed} pages.`;
                showNotification(`✅ Uploaded ${data.filename} and indexed ${data.chunks_inserted} chunks.`, 'success');
            } catch (error) {
                uploadSummary.textContent = 'Upload failed. Please try again.';
                showNotification('❌ Upload failed. Please try again.', 'error');
            } finally {
                uploadBtn.disabled = false;
                uploadBtn.textContent = 'Upload';
                fileInput.value = '';
            }
        }
    </script>
</body>
</html>
